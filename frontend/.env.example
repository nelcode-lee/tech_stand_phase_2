# Copy to .env.local for local overrides (not committed).

# Backend API base (see vite.config.js proxy / deployment)
# VITE_API_URL=http://127.0.0.1:8000

# Vite dev proxy: max time (ms) for /api requests. Full analysis on large SOPs can exceed 2 minutes.
# Default in vite.config.js is 600000 (10 min). Raise if runs still drop mid-stream.
# VITE_DEV_PROXY_TIMEOUT_MS=900000

# Epic D — draft / create positioning: assistive (default) | beta (show Beta labels) | minimal (de-emphasise Create in sidebar)
# VITE_DRAFT_OUTPUT_MODE=assistive
