# RAG ingestion: embeddings and vector store

# OpenAI (or Azure OpenAI) for embeddings
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_LLM_MODEL=gpt-4o
OPENAI_DRAFT_LLM_MODEL=gpt-4.1
# Optional: sampling temperature for most pipeline agents (default 0.2 if unset)
# OPENAI_LLM_TEMPERATURE=0.2
# Compliance flags, clause mapping, finding verification (default 0 — more repeatable harmonisation scores)
OPENAI_COMPLIANCE_TEMPERATURE=0
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Supabase (pgvector) — vector store for document chunks
# Get from Supabase Dashboard > Project Settings > Database > Connection string (URI)
# Format: postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=Tech_standards_bucket

# Frontend (Vite) — see frontend/.env.example
# Long analyses: if using the Vite dev server proxy, set VITE_DEV_PROXY_TIMEOUT_MS in frontend/.env.local (see frontend/.env.example).
# Deployed behind nginx/Caddy/etc.: increase proxy_read_timeout for /analyse streaming routes (often 60s by default).
